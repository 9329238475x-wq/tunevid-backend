# ──────────────────────────────────────────────
# TuneVid.com — Backend Environment Variables
# ──────────────────────────────────────────────

# Google OAuth (for YouTube API)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-signature-secret

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://tunevid:password@localhost:5432/tunevid

# JWT / Auth
NEXTAUTH_SECRET=your-nextauth-secret-key-min-32-chars

# Server
HOST=0.0.0.0
PORT=8000
